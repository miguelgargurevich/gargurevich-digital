generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model PortfolioProject {
  id            String   @id @default(cuid())
  slug          String   @unique
  titleEs       String
  titleEn       String
  descriptionEs String   @db.Text
  descriptionEn String   @db.Text
  featuresEs    String[]
  featuresEn    String[]
  tech          String[]
  github        String
  live          String   @default("#")
  color         String   @default("#00D4FF")
  imageUrl      String?
  order         Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Service {
  id               String    @id @default(cuid())
  slug             String    @unique
  icon             String    @default("code")
  titleEs          String
  titleEn          String
  descriptionEs    String    @db.Text
  descriptionEn    String    @db.Text
  featuresEs       String[]
  featuresEn       String[]
  serviceTier      String?
  recurringAmount  Decimal?  @db.Decimal(10, 2)
  currency         String    @default("PEN")
  order            Int       @default(0)
  published        Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model MediaFile {
  id        String   @id @default(cuid())
  filename  String
  key       String   @unique
  url       String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())
}

model Lead {
  id          String    @id @default(cuid())
  name        String
  email       String
  company     String?
  projectType String
  message     String    @db.Text
  status      LeadStatus @default(NEW)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdAt, id])
  @@index([status, createdAt, id])
  @@index([name, id])
  @@index([email])
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CLOSED_WON
  CLOSED_LOST
}

model Offer {
  id            String   @id @default(cuid())
  planKey       String   @unique
  icon          String   @default("zap")
  nameEs        String
  nameEn        String
  price         String
  renewalPrice  Decimal  @db.Decimal(10, 2)
  priceNoteEs   String
  priceNoteEn   String
  descriptionEs String   @db.Text
  descriptionEn String   @db.Text
  itemsEs       String[]
  itemsEn       String[]
  ctaEs         String   @default("Quiero este plan")
  ctaEn         String   @default("I want this plan")
  forWhoEs      String
  forWhoEn      String
  popular       Boolean  @default(false)
  order         Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
}

enum RenewalPlan {
  MONTHLY
  ANNUAL_10
  ANNUAL_15
}

model ClientSite {
  id                     String             @id @default(cuid())
  slug                   String             @unique
  businessName           String
  contractedService      String?
  serviceTier            String?
  setupFeeAmount         Decimal?           @db.Decimal(10, 2)
  recurringAmount        Decimal?           @db.Decimal(10, 2)
  currency               String             @default("PEN")
  billingEmail           String?
  billingContactName     String?
  billingContactPhone    String?
  notes                  String?            @db.Text
  status                 SubscriptionStatus @default(ACTIVE)
  setupFeePaidAt         DateTime?
  subscriptionStartsAt   DateTime?
  subscriptionEndsAt     DateTime?
  graceIncludedMonths    Int                @default(12)
  deactivatedAt          DateTime?
  deactivationReason     String?
  lastRenewalPlan        RenewalPlan?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  renewals               SubscriptionRenewal[]

  @@index([status, subscriptionEndsAt])
}

model SubscriptionRenewal {
  id              String      @id @default(cuid())
  clientSiteId    String
  clientSite      ClientSite  @relation(fields: [clientSiteId], references: [id], onDelete: Cascade)
  plan            RenewalPlan
  discountPercent Int         @default(0)
  amount          Decimal?    @db.Decimal(10, 2)
  startsAt        DateTime
  endsAt          DateTime
  createdAt       DateTime    @default(now())

  @@index([clientSiteId, startsAt])
}
